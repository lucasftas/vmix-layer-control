{
    "manifest_version": 3,
    "name": "vMix Layer Control",
    "version": "1.3.0",
    "description": "Controle visual de layers e multiview ao vivo para vMix — grid de botões, editor de layers e integração com Companion",
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "vMix Layer Control",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "http://*:8088/api",
                "http://*:8088/api*",
                "http://*:8089/api",
                "http://*:8089/api*",
                "http://*:8090/api",
                "http://*:8090/api*"
            ],
            "js": [
                "loader.js"
            ],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "index.html",
                "app.js",
                "lc-engine.js",
                "style.css",
                "icon16.png",
                "icon48.png",
                "icon128.png"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}